---
# Generated by Ansible — do not edit directly on the Jetson
# Edit: ansible/roles/homelab/templates/docker-compose.yml.j2

version: "3.9"

services:

  # ── Home Assistant ───────────────────────────────────────────────────────
  homeassistant:
    image: {{ homeassistant_image }}
    container_name: homeassistant
    restart: unless-stopped
    privileged: true              # needed for USB dongles (Zigbee/Z-Wave)
    network_mode: host            # required for mDNS/device discovery
    environment:
      TZ: "${TZ}"
    volumes:
      - {{ docker_compose_dir }}/homeassistant/config:/config
      - /run/dbus:/run/dbus:ro   # Bluetooth support
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8123"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s

  # ── UniFi Network Application ────────────────────────────────────────────
  unifi-controller:
    image: {{ unifi_image }}
    container_name: unifi-controller
    restart: unless-stopped
    depends_on:
      unifi-db:
        condition: service_healthy
    environment:
      PUID: "${PUID}"
      PGID: "${PGID}"
      TZ: "${TZ}"
      MONGO_USER: "${MONGO_UNIFI_USER}"
      MONGO_PASS: "${MONGO_UNIFI_PASSWORD}"
      MONGO_HOST: "{{ unifi_mongo_host }}"
      MONGO_PORT: "{{ unifi_mongo_port }}"
      MONGO_DBNAME: "{{ unifi_mongo_dbname }}"
    volumes:
      - {{ docker_compose_dir }}/unifi/data:/config
    ports:
      - "{{ unifi_https_port }}:8443"       # HTTPS web UI
      - "{{ unifi_inform_port }}:8080"      # device inform
      - "{{ unifi_stun_port }}:3478/udp"   # STUN
      - "10001:10001/udp"                   # AP discovery
      - "8843:8843"                         # HTTPS guest portal
      - "8880:8880"                         # HTTP guest portal
      - "6789:6789"                         # mobile throughput test

  # ── MongoDB (UniFi dependency) ───────────────────────────────────────────
  # IMPORTANT: Mongo 5+ uses AVX CPU instructions not available on ARM/Jetson.
  # mongo:4.4 is a hard requirement for this platform.
  unifi-db:
    image: {{ mongo_image }}
    container_name: unifi-db
    restart: unless-stopped
    environment:
      MONGO_INITDB_ROOT_USERNAME: "${MONGO_ROOT_USER}"
      MONGO_INITDB_ROOT_PASSWORD: "${MONGO_ROOT_PASSWORD}"
      MONGO_INITDB_DATABASE: "{{ unifi_mongo_dbname }}"
    volumes:
      - {{ docker_compose_dir }}/unifi/db:/data/db
      - {{ docker_compose_dir }}/unifi/init-mongo.js:/docker-entrypoint-initdb.d/init-mongo.js:ro
    healthcheck:
      test: ["CMD", "mongo", "--eval", "db.adminCommand('ping')"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s

  # ── Portainer ────────────────────────────────────────────────────────────
  portainer:
    image: {{ portainer_image }}
    container_name: portainer
    restart: unless-stopped
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - {{ docker_compose_dir }}/portainer/data:/data
    ports:
      - "{{ portainer_port }}:9443"

  # ── GPU workload template (disabled by default) ──────────────────────────
  # Uncomment and customize when you're ready to run GPU containers.
  # Any service with runtime: nvidia will have access to the Jetson's GPU.
  #
  # gpu-service:
  #   image: your-gpu-image:latest
  #   container_name: gpu-service
  #   restart: unless-stopped
  #   runtime: nvidia
  #   environment:
  #     NVIDIA_VISIBLE_DEVICES: all
  #     NVIDIA_DRIVER_CAPABILITIES: compute,utility
  #   # Shared memory is 8GB total (CPU + GPU combined) — monitor with jtop
